{
	"$schema": "https://raw.githubusercontent.com/badlogic/pi-mono/main/packages/coding-agent/src/modes/interactive/theme/theme-schema.json",
	"name": "vercel-minimal",
	"vars": {
		"cyan": "#0a72ef",
		"blue": "#0a72ef",
		"green": "#0a72ef",
		"red": "#ff5b4f",
		"yellow": "#de1d8d",
		"gray": "#999999",
		"dimGray": "#666666",
		"darkGray": "#333333",
		"accent": "#0a72ef",
		"selectedBg": "#1f1f1f",
		"userMsgBg": "#171717",
		"toolPendingBg": "#1f1f1f",
		"toolSuccessBg": "#0a1f2e",
		"toolErrorBg": "#331a1a",
		"customMsgBg": "#1f1f1f"
	},
	"colors": {
		"accent": "accent",
		"border": "darkGray",
		"borderAccent": "blue",
		"borderMuted": "dimGray",
		"success": "blue",
		"error": "red",
		"warning": "yellow",
		"muted": "gray",
		"dim": "dimGray",
		"text": "",
		"thinkingText": "gray",
		"selectedBg": "selectedBg",
		"userMessageBg": "userMsgBg",
		"userMessageText": "",
		"customMessageBg": "customMsgBg",
		"customMessageText": "",
		"customMessageLabel": "blue",
		"toolPendingBg": "toolPendingBg",
		"toolSuccessBg": "toolSuccessBg",
		"toolErrorBg": "toolErrorBg",
		"toolTitle": "",
		"toolOutput": "gray",
		"mdHeading": "blue",
		"mdLink": "cyan",
		"mdLinkUrl": "dimGray",
		"mdCode": "blue",
		"mdCodeBlock": "gray",
		"mdCodeBlockBorder": "darkGray",
		"mdQuote": "gray",
		"mdQuoteBorder": "blue",
		"mdHr": "darkGray",
		"mdListBullet": "blue",
		"toolDiffAdded": "blue",
		"toolDiffRemoved": "red",
		"toolDiffContext": "gray",
		"syntaxComment": "#666666",
		"syntaxKeyword": "blue",
		"syntaxFunction": "cyan",
		"syntaxVariable": "gray",
		"syntaxString": "yellow",
		"syntaxNumber": "blue",
		"syntaxType": "cyan",
		"syntaxOperator": "gray",
		"syntaxPunctuation": "dimGray",
		"thinkingOff": "darkGray",
		"thinkingMinimal": "dimGray",
		"thinkingLow": "gray",
		"thinkingMedium": "blue",
		"thinkingHigh": "blue",
		"thinkingXhigh": "blue",
		"bashMode": "blue"
	},
	"export": {
		"pageBg": "#171717",
		"cardBg": "#1f1f1f",
		"infoBg": "#262626"
	},
	"meta": {
		"borderRadius": "0px",
		"fontPrimary": "Consolas, Monaco, 'Courier New', monospace",
		"fontMono": "Consolas, Monaco, Menlo, monospace",
		"fontSizes": {
			"small": "12px",
			"medium": "14px",
			"large": "16px",
			"heading": "20px",
			"display": "28px"
		}
	},
	"geometry": {
		"spacing": {
			"xs": "4px",
			"sm": "8px",
			"md": "12px",
			"lg": "16px",
			"xl": "20px",
			"xxl": "24px"
		},
		"borderWidth": "1px",
		"glassOpacity": "0.02",
		"focusOutlineWidth": "1px"
	},
	"shadows": {
		"none": "none",
		"flat": "0 0 0 1px rgba(10, 114, 239, 0.2)",
		"border": "0 0 0 1px rgba(51, 51, 51, 1)",
		"glow": "0 0 6px rgba(10, 114, 239, 0.3)"
	},
	"components": {
		"terminal": {
			"background": "#0a0a0a",
			"foreground": "#0a72ef",
			"cursor": "#0a72ef",
			"selection": "rgba(10, 114, 239, 0.25)"
		},
		"sidebar": {
			"background": "#0a0a0a",
			"border": "#333333",
			"itemHover": "#1f1f1f",
			"itemActive": "#0a72ef"
		},
		"monitor": {
			"graphAccent": "#0a72ef",
			"graphSuccess": "#0a72ef",
			"graphWarning": "#de1d8d",
			"graphError": "#ff5b4f",
			"gridColor": "#333333"
		},
		"editor": {
			"background": "#171717",
			"lineNumberColor": "#666666",
			"selectionBg": "rgba(10, 114, 239, 0.18)",
			"cursorColor": "#0a72ef"
		}
	}
}
