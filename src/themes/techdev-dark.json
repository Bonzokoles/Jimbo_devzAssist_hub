{
	"$schema": "https://raw.githubusercontent.com/badlogic/pi-mono/main/packages/coding-agent/src/modes/interactive/theme/theme-schema.json",
	"name": "techdev-dark",
	"vars": {
		"cyan": "#00f0ff",
		"blue": "#0080ff",
		"green": "#00ed64",
		"red": "#ff5b4f",
		"yellow": "#ffff00",
		"gray": "#afaeac",
		"dimGray": "#868584",
		"darkGray": "#353534",
		"accent": "#00ed64",
		"selectedBg": "#1c1c1c",
		"userMsgBg": "#1c1c1c",
		"toolPendingBg": "#1c1c1c",
		"toolSuccessBg": "#1c1c1c",
		"toolErrorBg": "#1c1c1c",
		"customMsgBg": "#1c1c1c"
	},
	"colors": {
		"accent": "accent",
		"border": "darkGray",
		"borderAccent": "accent",
		"borderMuted": "dimGray",
		"success": "green",
		"error": "red",
		"warning": "yellow",
		"muted": "gray",
		"dim": "dimGray",
		"text": "",
		"thinkingText": "gray",
		"selectedBg": "selectedBg",
		"userMessageBg": "userMsgBg",
		"userMessageText": "",
		"customMessageBg": "customMsgBg",
		"customMessageText": "",
		"customMessageLabel": "accent",
		"toolPendingBg": "toolPendingBg",
		"toolSuccessBg": "toolSuccessBg",
		"toolErrorBg": "toolErrorBg",
		"toolTitle": "",
		"toolOutput": "gray",
		"mdHeading": "accent",
		"mdLink": "blue",
		"mdLinkUrl": "dimGray",
		"mdCode": "accent",
		"mdCodeBlock": "green",
		"mdCodeBlockBorder": "gray",
		"mdQuote": "gray",
		"mdQuoteBorder": "gray",
		"mdHr": "gray",
		"mdListBullet": "accent",
		"toolDiffAdded": "green",
		"toolDiffRemoved": "red",
		"toolDiffContext": "gray",
		"syntaxComment": "#4e6645",
		"syntaxKeyword": "blue",
		"syntaxFunction": "yellow",
		"syntaxVariable": "green",
		"syntaxString": "green",
		"syntaxNumber": "yellow",
		"syntaxType": "blue",
		"syntaxOperator": "gray",
		"syntaxPunctuation": "dimGray",
		"thinkingOff": "darkGray",
		"thinkingMinimal": "dimGray",
		"thinkingLow": "gray",
		"thinkingMedium": "blue",
		"thinkingHigh": "green",
		"thinkingXhigh": "accent",
		"bashMode": "green"
	},
	"export": {
		"pageBg": "#0d0d0d",
		"cardBg": "#1c1c1c",
		"infoBg": "#1c1c1c"
	},
	"meta": {
		"borderRadius": "0px",
		"fontPrimary": "CascadiaCode, 'Cascadia Code', Consolas, Monaco, 'Courier New', monospace",
		"fontMono": "FiraCode, 'Fira Code', 'Cascadia Mono', Menlo, monospace",
		"fontSizes": {
			"small": "12px",
			"medium": "14px",
			"large": "16px",
			"heading": "24px",
			"display": "32px"
		}
	},
	"geometry": {
		"spacing": {
			"xs": "4px",
			"sm": "8px",
			"md": "12px",
			"lg": "16px",
			"xl": "24px",
			"xxl": "32px"
		},
		"borderWidth": "1px",
		"glassOpacity": "0.05",
		"focusOutlineWidth": "2px"
	},
	"shadows": {
		"none": "none",
		"flat": "0 0 0 1px rgba(0, 237, 100, 0.2)",
		"border": "0 0 0 1px rgba(53, 53, 52, 1)",
		"glow": "0 0 8px rgba(0, 237, 100, 0.4)"
	},
	"components": {
		"terminal": {
			"background": "#001e2b",
			"foreground": "#00ed64",
			"cursor": "#00ed64",
			"selection": "rgba(0, 237, 100, 0.3)"
		},
		"sidebar": {
			"background": "#0a0a0a",
			"border": "#353534",
			"itemHover": "#1c1c1c",
			"itemActive": "#00ed64"
		},
		"monitor": {
			"graphAccent": "#00ed64",
			"graphSuccess": "#00ff41",
			"graphWarning": "#ffff00",
			"graphError": "#ff5b4f",
			"gridColor": "#353534"
		},
		"editor": {
			"background": "#0d0d0d",
			"lineNumberColor": "#868584",
			"selectionBg": "rgba(0, 237, 100, 0.2)",
			"cursorColor": "#00ed64"
		}
	}
}
