{
	"$schema": "https://raw.githubusercontent.com/badlogic/pi-mono/main/packages/coding-agent/src/modes/interactive/theme/theme-schema.json",
	"name": "terminal-neon",
	"vars": {
		"cyan": "#00f0ff",
		"blue": "#0080ff",
		"green": "#00ed64",
		"red": "#ff5b4f",
		"yellow": "#ffff00",
		"gray": "#cccccc",
		"dimGray": "#868584",
		"darkGray": "#2a4a52",
		"accent": "#00ed64",
		"selectedBg": "#0a2e3b",
		"userMsgBg": "#001e2b",
		"toolPendingBg": "#0a2e3b",
		"toolSuccessBg": "#00331f",
		"toolErrorBg": "#330a0a",
		"customMsgBg": "#0a2e3b"
	},
	"colors": {
		"accent": "accent",
		"border": "darkGray",
		"borderAccent": "green",
		"borderMuted": "dimGray",
		"success": "green",
		"error": "red",
		"warning": "yellow",
		"muted": "gray",
		"dim": "dimGray",
		"text": "",
		"thinkingText": "gray",
		"selectedBg": "selectedBg",
		"userMessageBg": "userMsgBg",
		"userMessageText": "",
		"customMessageBg": "customMsgBg",
		"customMessageText": "",
		"customMessageLabel": "green",
		"toolPendingBg": "toolPendingBg",
		"toolSuccessBg": "toolSuccessBg",
		"toolErrorBg": "toolErrorBg",
		"toolTitle": "",
		"toolOutput": "gray",
		"mdHeading": "green",
		"mdLink": "cyan",
		"mdLinkUrl": "dimGray",
		"mdCode": "green",
		"mdCodeBlock": "green",
		"mdCodeBlockBorder": "darkGray",
		"mdQuote": "gray",
		"mdQuoteBorder": "green",
		"mdHr": "darkGray",
		"mdListBullet": "green",
		"toolDiffAdded": "green",
		"toolDiffRemoved": "red",
		"toolDiffContext": "gray",
		"syntaxComment": "#868584",
		"syntaxKeyword": "green",
		"syntaxFunction": "cyan",
		"syntaxVariable": "blue",
		"syntaxString": "green",
		"syntaxNumber": "green",
		"syntaxType": "cyan",
		"syntaxOperator": "gray",
		"syntaxPunctuation": "dimGray",
		"thinkingOff": "darkGray",
		"thinkingMinimal": "dimGray",
		"thinkingLow": "gray",
		"thinkingMedium": "blue",
		"thinkingHigh": "green",
		"thinkingXhigh": "green",
		"bashMode": "green"
	},
	"export": {
		"pageBg": "#001e2b",
		"cardBg": "#0a2e3b",
		"infoBg": "#0d3844"
	},
	"meta": {
		"borderRadius": "0px",
		"fontPrimary": "Source Code Pro, 'Source Code Pro', Monaco, Consolas, monospace",
		"fontMono": "Source Code Pro, 'Source Code Pro', Menlo, monospace",
		"fontSizes": {
			"small": "13px",
			"medium": "15px",
			"large": "17px",
			"heading": "26px",
			"display": "36px"
		}
	},
	"geometry": {
		"spacing": {
			"xs": "4px",
			"sm": "8px",
			"md": "12px",
			"lg": "16px",
			"xl": "24px",
			"xxl": "32px"
		},
		"borderWidth": "1px",
		"glassOpacity": "0.08",
		"focusOutlineWidth": "2px"
	},
	"shadows": {
		"none": "none",
		"flat": "0 0 0 1px rgba(0, 237, 100, 0.3)",
		"border": "0 0 0 1px rgba(42, 74, 82, 1)",
		"glow": "0 0 10px rgba(0, 237, 100, 0.5), 0 0 20px rgba(0, 237, 100, 0.2)"
	},
	"components": {
		"terminal": {
			"background": "#001118",
			"foreground": "#00ed64",
			"cursor": "#00ff41",
			"selection": "rgba(0, 237, 100, 0.35)"
		},
		"sidebar": {
			"background": "#001118",
			"border": "#2a4a52",
			"itemHover": "#0a2e3b",
			"itemActive": "#00ed64"
		},
		"monitor": {
			"graphAccent": "#00ed64",
			"graphSuccess": "#00ff41",
			"graphWarning": "#ffff00",
			"graphError": "#ff5b4f",
			"gridColor": "#2a4a52"
		},
		"editor": {
			"background": "#001e2b",
			"lineNumberColor": "#868584",
			"selectionBg": "rgba(0, 237, 100, 0.25)",
			"cursorColor": "#00ff41"
		}
	}
}
